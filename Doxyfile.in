# Doxyfile.in — configured by CMake, do not edit the generated Doxyfile directly.

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "@PROJECT_NAME@"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "Git repository manager"
OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIR@"

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = "@CMAKE_SOURCE_DIR@/app"
RECURSIVE              = YES
FILE_PATTERNS          = *.h
EXCLUDE_PATTERNS       = */build/* \
                         */build-*/* \
                         *_autogen/* \
                         */moc_*.cpp

#---------------------------------------------------------------------------
# Extraction
#---------------------------------------------------------------------------
# Only document symbols that have explicit Doxygen comments.
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES

#---------------------------------------------------------------------------
# Comment style
#---------------------------------------------------------------------------
# Treat /** ... */ blocks as brief+detailed (Javadoc mode).
JAVADOC_AUTOBRIEF      = YES
# Recognise @param, @return, etc. without a leading backslash.
OPTIMIZE_OUTPUT_FOR_C  = NO
QT_AUTOBRIEF           = NO

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO

#---------------------------------------------------------------------------
# Output formats
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_XML           = NO

#---------------------------------------------------------------------------
# Diagrams
#---------------------------------------------------------------------------
HAVE_DOT               = NO
CLASS_DIAGRAMS         = YES

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
